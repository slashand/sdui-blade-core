{
  "name": "@slashand/sdui-blade-core",
  "version": "1.0.0-alpha.2",
  "description": "Framework-agnostic JSON-driven Blade orchestrator for Server-Driven UI architectures.",
  "author": "Slashand LLC",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "sdui",
    "server-driven-ui",
    "blade-system",
    "orchestration",
    "json-ui",
    "micro-frontends",
    "journey-protocol"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/slashand/sdui-blade-core.git"
  },
  "bugs": {
    "url": "https://github.com/slashand/sdui-blade-core/issues"
  },
  "homepage": "https://github.com/slashand/sdui-blade-core#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "test": "vitest run",
    "publish:alpha": "npm version prerelease --preid=alpha --no-git-tag-version && npm run build && npm publish --tag alpha",
    "publish:prod": "npm version patch --no-git-tag-version && npm run build && npm publish",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
